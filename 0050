<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>0050 購物換算器</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
}

body{
    background:#f5f7fb;
    min-height:100vh;
    padding:30px 15px;
    color:#111;
}

.container{
    max-width:720px;
    margin:auto;
}

.title{
    font-size:34px;
    font-weight:800;
    margin-bottom:10px;
}

.subtitle{
    color:#666;
    line-height:1.7;
    margin-bottom:28px;
}

.card{
    background:#fff;
    border-radius:28px;
    padding:26px;
    box-shadow:0 10px 30px rgba(0,0,0,.08);
    margin-bottom:24px;
}

.label{
    font-size:14px;
    font-weight:700;
    margin-bottom:10px;
    display:block;
}

.input{
    width:100%;
    height:58px;
    border:none;
    background:#f1f4f9;
    border-radius:18px;
    padding:0 18px;
    font-size:18px;
    outline:none;
    margin-bottom:20px;
}

.stock-row{
    display:flex;
    gap:12px;
}

.stock-row .input{
    margin-bottom:0;
}

button{
    border:none;
    background:#00b16a;
    color:white;
    padding:16px 24px;
    border-radius:18px;
    font-size:17px;
    font-weight:700;
    cursor:pointer;
    transition:.2s;
}

button:hover{
    transform:translateY(-2px);
    opacity:.92;
}

.result{
    display:none;
    animation:fade .35s ease;
}

@keyframes fade{
    from{
        opacity:0;
        transform:translateY(10px);
    }
    to{
        opacity:1;
        transform:translateY(0);
    }
}

.main-money{
    background:linear-gradient(135deg,#00c77b,#00a663);
    color:white;
    border-radius:24px;
    padding:26px;
    margin-bottom:20px;
}

.main-money h2{
    font-size:18px;
    opacity:.9;
    margin-bottom:12px;
}

.big{
    font-size:42px;
    font-weight:900;
}

.grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:16px;
}

.small-card{
    background:#f7f9fc;
    border-radius:22px;
    padding:20px;
}

.small-card h3{
    font-size:15px;
    color:#666;
    margin-bottom:12px;
}

.small-card .value{
    font-size:30px;
    font-weight:800;
    margin-bottom:6px;
}

.gain{
    color:#00a663;
    font-weight:700;
}

.info{
    margin-top:22px;
    background:#eefaf5;
    border:2px solid #c8f0dc;
    padding:18px;
    border-radius:18px;
    line-height:1.8;
}

.info b{
    color:#00a663;
}

.footer{
    text-align:center;
    color:#888;
    margin-top:20px;
    font-size:14px;
}

.tag{
    display:inline-flex;
    align-items:center;
    gap:8px;
    background:#00b16a;
    color:white;
    padding:8px 14px;
    border-radius:999px;
    font-size:14px;
    font-weight:700;
    margin-bottom:18px;
}

.dot{
    width:8px;
    height:8px;
    background:#fff;
    border-radius:50%;
}

@media(max-width:640px){

    .title{
        font-size:28px;
    }

    .grid{
        grid-template-columns:1fr;
    }

    .stock-row{
        flex-direction:column;
    }

    button{
        width:100%;
    }
}
</style>
</head>
<body>

<div class="container">

    <div class="tag">
        <div class="dot"></div>
        All in ETF 模擬器
    </div>

    <div class="title">
        這筆錢如果拿去買 ETF？
    </div>

    <div class="subtitle">
        輸入商品價格，立刻換算成可以買幾股 ETF，
        並模擬 3 個月後與 1 年後可能變成多少錢。
    </div>

    <div class="card">

        <label class="label">商品價格（NTD）</label>
        <input id="price" class="input" type="number" placeholder="例如 47508">

        <div class="stock-row">

            <div style="flex:1">
                <label class="label">ETF 名稱</label>
                <input id="stockName" class="input" value="元大台灣50">
            </div>

            <div style="width:160px">
                <label class="label">代號</label>
                <input id="stockCode" class="input" value="0050">
            </div>

        </div>

        <div style="height:18px"></div>

        <label class="label">目前股價</label>
        <input id="stockPrice" class="input" type="number" value="196.9">

        <label class="label">歷史年化報酬率（%）</label>
        <input id="annualReturn" class="input" type="number" value="12">

        <button onclick="calculate()">
            開始換算
        </button>

    </div>

    <div class="result" id="result">

        <div class="main-money">
            <h2>你可以買入</h2>
            <div class="big" id="shares">0 股</div>

            <div style="margin-top:14px;font-size:18px;opacity:.92">
                約 NT$ <span id="usedMoney">0</span>
            </div>
        </div>

        <div class="grid">

            <div class="small-card">
                <h3>3 個月後可能變成</h3>
                <div class="value" id="future3m">0</div>
                <div class="gain" id="gain3m">+0%</div>
            </div>

            <div class="small-card">
                <h3>1 年後可能變成</h3>
                <div class="value" id="future1y">0</div>
                <div class="gain" id="gain1y">+0%</div>
            </div>

        </div>

        <div class="info" id="infoText"></div>

    </div>

    <div class="footer">
        僅供模擬與娛樂用途，不構成投資建議
    </div>

</div>

<script>
function format(num){
    return Number(num).toLocaleString("zh-TW",{
        maximumFractionDigits:0
    });
}

function calculate(){

    const price = Number(document.getElementById("price").value);

    const stockName = document.getElementById("stockName").value;

    const stockCode = document.getElementById("stockCode").value;

    const stockPrice = Number(document.getElementById("stockPrice").value);

    const annualReturn = Number(document.getElementById("annualReturn").value);

    if(!price || !stockPrice){
        alert("請輸入正確金額");
        return;
    }

    const shares = price / stockPrice;

    const annualRate = annualReturn / 100;

    const future3m =
        price * Math.pow(1 + annualRate, 0.25);

    const future1y =
        price * (1 + annualRate);

    const gain3m =
        ((future3m - price) / price * 100).toFixed(1);

    const gain1y =
        ((future1y - price) / price * 100).toFixed(1);

    document.getElementById("shares").innerText =
        shares.toFixed(2) + " 股";

    document.getElementById("usedMoney").innerText =
        format(price);

    document.getElementById("future3m").innerText =
        "NT$ " + format(future3m);

    document.getElementById("future1y").innerText =
        "NT$ " + format(future1y);

    document.getElementById("gain3m").innerText =
        "+" + gain3m + "%";

    document.getElementById("gain1y").innerText =
        "+" + gain1y + "%";

    document.getElementById("infoText").innerHTML =
        `
        如果這筆 <b>NT$ ${format(price)}</b>
        沒有拿去消費，而是投入
        <b>${stockName} (${stockCode})</b>，
        依照歷史年化報酬率
        <b>${annualReturn}%</b> 推估，
        未來可能產生不同的資產成長效果。
        `;

    document.getElementById("result").style.display = "block";

    window.scrollTo({
        top:document.body.scrollHeight,
        behavior:"smooth"
    });
}
</script>

</body>
</html>
