<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>✦ 太極鰲車輪餅．魔法結算工坊 ✦</title>

    <meta name="robots" content="noindex,nofollow,noarchive,nosnippet,noimageindex">
    <meta name="googlebot" content="noindex,nofollow,noarchive,nosnippet,noimageindex">
    <meta name="bingbot" content="noindex,nofollow,noarchive,nosnippet,noimageindex">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Cormorant+Garamond:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            transition: font-size 0.2s ease, transform 0.4s ease, box-shadow 0.4s ease, background-color 0.3s ease, border-color 0.3s ease;
        }

        :root {
            --bg1: #171320;
            --bg2: #241a35;
            --bg3: #31244d;
            --gold: #d8bf8a;
            --text: #f4efff;
            --card: rgba(29, 24, 44, .72);
            --gold-low: rgba(216, 191, 138, 0.15);
            --base-font-size: 16px;
        }

        body {
            min-height: 100vh;
            color: var(--text);
            font-family: "Cormorant Garamond", "Microsoft JhengHei", serif;
            background: radial-gradient(circle at top, rgba(180,150,255,.14), transparent 40%),
                        linear-gradient(180deg, var(--bg1), var(--bg2), var(--bg3));
            padding: 28px;
            position: relative;
            font-size: var(--base-font-size);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .stars { position: fixed; inset: 0; overflow: hidden; z-index: -3; pointer-events: none; }
        .star { position: absolute; width: 2px; height: 2px; background: white; border-radius: 50%; opacity: .7; animation: twinkle 4s infinite; }
        @keyframes twinkle { 0%, 100% { opacity: .15; transform: scale(.7); } 50% { opacity: 1; transform: scale(1.4); } }

        .frame { position: fixed; inset: 14px; border: 1.5px solid rgba(216,191,138,.48); border-radius: 38px; pointer-events: none; z-index: 999; }
        .frame::before { content: ""; position: absolute; inset: 12px; border: 1px solid rgba(216,191,138,.18); border-radius: 30px; }

        .corner { position: fixed; width: 120px; height: 120px; pointer-events: none; z-index: 1000; }
        .corner::before { content: ""; position: absolute; inset: 0; border: 1.5px solid rgba(216,191,138,.45); border-radius: 50%; }
        .corner::after { content: "✦"; position: absolute; color: rgba(216,191,138,.85); font-size: 26px; }
        .tl { top: 18px; left: 18px; } .tl::before { clip-path: polygon(0 0, 100% 0, 0 100%); } .tl::after { top: 18px; left: 18px; }
        .tr { top: 18px; right: 18px; } .tr::before { clip-path: polygon(0 0, 100% 0, 100% 100%); } .tr::after { top: 18px; right: 18px; }
        .bl { bottom: 18px; left: 18px; } .bl::before { clip-path: polygon(0 0, 0 100%, 100% 100%); } .bl::after { bottom: 18px; left: 18px; }
        .br { bottom: 18px; right: 18px; } .br::before { clip-path: polygon(100% 0, 0 100%, 100% 100%); } .br::after { bottom: 18px; right: 18px; }

        .container { width: 100%; max-width: 1040px; margin: auto; position: relative; z-index: 2; padding: 20px 0; }

        .font-control { display: flex; justify-content: flex-end; gap: 10px; margin-bottom: -10px; position: relative; z-index: 1010; }
        .font-btn { background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(216, 191, 138, 0.3); color: var(--text); padding: 6px 14px; border-radius: 20px; cursor: pointer; font-family: "Cinzel", serif; font-size: 14px; backdrop-filter: blur(5px); }
        .font-btn:hover { background: rgba(216, 191, 138, 0.2); color: var(--gold); border-color: var(--gold); }
        .font-btn.active { background: var(--gold); color: var(--bg1); font-weight: bold; border-color: var(--gold); }

        .moon { text-align: center; margin-top: 10px; position: relative; }
        .moon::before { content: ""; position: absolute; left: 50%; top: -50px; width: 1px; height: 50px; background: rgba(216,191,138,.35); }
        .moon-symbol { font-size: 42px; color: var(--gold); text-shadow: 0 0 18px rgba(216,191,138,.25); animation: floatMoon 4s ease-in-out infinite; }
        @keyframes floatMoon { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(6px); } }

        .title-block { text-align: center; margin-top: 15px; margin-bottom: 35px; }
        .main-title { font-family: "Microsoft JhengHei", "Cinzel", serif; font-weight: 700; letter-spacing: 2px; line-height: 1.3; font-size: clamp(26px, 5vw, 40px); background: linear-gradient(180deg, #ffffff 0%, #f1e8ff 40%, #d8bf8a 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

        .layout-grid { display: flex; flex-direction: column; gap: 28px; }
        @media (min-width: 950px) { .layout-grid { flex-direction: row; align-items: stretch; } }

        .main-calculator { flex: 1; background: var(--card); border: 1px solid rgba(255,255,255,.06); border-radius: 34px; padding: 28px; backdrop-filter: blur(16px); box-shadow: 0 20px 50px rgba(0,0,0,.3); display: flex; flex-direction: column; }
        .sidebar-panel { width: 100%; background: var(--card); border: 1px solid rgba(255,255,255,.06); border-radius: 34px; padding: 28px; backdrop-filter: blur(16px); box-shadow: 0 20px 50px rgba(0,0,0,.3); display: flex; flex-direction: column; }
        @media (min-width: 950px) { .sidebar-panel { width: 380px; } }

        /* 分類頁籤導覽列 */
        .category-tabs { display: flex; gap: 8px; margin-bottom: 16px; overflow-x: auto; padding-bottom: 6px; }
        .tab-btn { background: rgba(255,255,255,0.03); border: 1px solid rgba(216,191,138,0.2); color: #c4b7e2; padding: 8px 14px; border-radius: 12px; cursor: pointer; font-size: 13px; white-space: nowrap; }
        .tab-btn:hover { border-color: var(--gold); color: var(--gold); }
        .tab-btn.active { background: rgba(216,191,138,0.15); border-color: var(--gold); color: var(--gold); font-weight: bold; }

        /* 口味捲動列表容器 */
        .flavor-scroll-area { max-height: 380px; overflow-y: auto; padding-right: 4px; margin-bottom: 15px; }
        .flavor-group-pane { display: none; }
        .flavor-group-pane.active { display: block; }

        .form-label { display: block; font-size: calc(var(--base-font-size) * 0.9); color: #bba9e8; margin-bottom: 8px; letter-spacing: 1px; }
        .form-group { margin-bottom: 16px; }
        .classic-input { width: 100%; background: rgba(15, 11, 25, 0.5); border: 1px solid rgba(216, 191, 138, 0.25); border-radius: 16px; padding: 12px 16px; color: #ffffff; font-size: calc(var(--base-font-size) * 1.05); }
        .classic-input:focus { outline: none; border-color: var(--gold); box-shadow: 0 0 12px rgba(216, 191, 138, 0.2); }

        .flavor-row { display: flex; align-items: center; justify-content: space-between; background: rgba(255,255,255,0.02); padding: 10px 14px; border-radius: 14px; margin-bottom: 8px; border: 1px solid rgba(216,191,138,0.08); }
        .flavor-info { display: flex; flex-direction: column; gap: 2px; }
        .flavor-name { font-size: calc(var(--base-font-size) * 1.0); color: var(--text); font-weight: 600; }
        .flavor-price { font-size: 12px; color: var(--gold); }

        .counter-controls { display: flex; align-items: center; gap: 10px; }
        .counter-btn { width: 30px; height: 30px; border-radius: 50%; border: 1px solid rgba(216,191,138,0.4); background: rgba(15, 11, 25, 0.6); color: var(--gold); cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center; }
        .counter-btn:hover { background: var(--gold); color: var(--bg1); }
        .counter-value { font-family: 'Courier New', monospace; font-size: calc(var(--base-font-size) * 1.05); font-weight: bold; width: 22px; text-align: center; }

        .magic-btn { width: 100%; background: linear-gradient(135deg, rgba(216,191,138,0.9) 0%, rgba(180,150,255,0.3) 100%); border: 1px solid var(--gold); color: #171320; padding: 14px; border-radius: 18px; cursor: pointer; font-family: "Microsoft JhengHei", serif; font-weight: bold; font-size: calc(var(--base-font-size) * 1.05); box-shadow: 0 4px 15px rgba(216,191,138,0.2); margin-top: auto; }
        .magic-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(216,191,138,0.4); background: linear-gradient(135deg, rgba(216,191,138,1) 0%, rgba(180,150,255,0.5) 100%); }
        .secondary-btn { background: rgba(255,255,255,0.05); border: 1px solid rgba(216,191,138,0.3); color: var(--gold); }
        .secondary-btn:hover { background: rgba(216,191,138,0.1); color: #ffffff; }

        .ledger-list { max-height: 280px; overflow-y: auto; margin-bottom: 15px; padding-right: 4px; }
        .ledger-item { padding: 10px 0; border-bottom: 1px dashed rgba(216,191,138,0.15); font-size: calc(var(--base-font-size) * 0.85); display: flex; justify-content: space-between; align-items: center; }
        .ledger-name { color: var(--gold); font-weight: 600; }
        .ledger-detail { color: #c4b7e2; }
        .delete-record { color: #f29494; cursor: pointer; margin-left: 10px; font-size: 14px; padding: 0 4px; }

        .summary-box { background: rgba(216,191,138,0.06); border: 1px solid rgba(216, 191, 138, 0.2); border-radius: 16px; padding: 14px; margin-top: auto; }
        .summary-row { display: flex; justify-content: space-between; margin-bottom: 6px; font-size: calc(var(--base-font-size) * 0.95); }
        .classic-hr { margin: 20px 0; border: none; height: 1px; background: linear-gradient(90deg, transparent, rgba(216,191,138,.4), transparent); }

        .sidebar-title { font-family: "Microsoft JhengHei", serif; font-size: calc(var(--base-font-size) * 1.15); color: var(--gold); text-align: center; margin-bottom: 6px; }
        .sidebar-desc { font-size: 13px; color: #a897c9; text-align: center; margin-bottom: 16px; font-style: italic; }

        .toast { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%) translateY(100px); background: rgba(36, 26, 53, 0.95); border: 1px solid var(--gold); color: var(--text); padding: 10px 24px; border-radius: 30px; z-index: 2000; opacity: 0; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); font-size: 14px; text-align: center; }
        .toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }

        .color-gold { color: var(--gold); }
        .color-mint { color: #8ae0be; }
        #captureCanvas { display: none; }

        .footer { text-align: center; margin-top: 35px; }
        .footer-line { width: 100px; height: 1px; margin: auto; margin-bottom: 14px; background: linear-gradient(90deg, transparent, rgba(216,191,138,.5), transparent); }
        .footer-inner { display: flex; align-items: center; justify-content: center; gap: 12px; font-family: "Cinzel", serif; font-size: 20px; color: #eadfff; }
        .creator { margin-top: 6px; font-size: 13px; color: #a897c9; font-style: italic; }
    </style>
</head>
<body>

<div class="stars" id="stars"></div>
<div class="frame"></div>
<div class="corner tl"></div><div class="corner tr"></div><div class="corner bl"></div><div class="corner br"></div>

<div class="container">
    <div class="font-control">
        <button class="font-btn" onclick="changeFontSize('small', this)">A -</button>
        <button class="font-btn active" onclick="changeFontSize('medium', this)">A</button>
        <button class="font-btn" onclick="changeFontSize('large', this)">A +</button>
    </div>

    <div class="moon"><div class="moon-symbol">☾</div></div>

    <div class="title-block">
        <h1 class="main-title">🥞 太極鰲車輪餅 🥞<br>辦公室魔法結算工坊</h1>
    </div>

    <div class="layout-grid">
        
        <div class="main-calculator" id="mainCorePanel">
            <div class="form-group">
                <label class="form-label">✦ 同事姓名／暱稱</label>
                <input type="text" id="memberInput" class="classic-input" placeholder="請輸入名字，避免吃空單..." autocomplete="off">
            </div>

            <label class="form-label">✦ 選擇口味分類區（點擊切換分流）</label>
            <div class="category-tabs" id="tabBar">
                <button class="tab-btn active" onclick="switchCategory('cat15')">15元經典區</button>
                <button class="tab-btn" onclick="switchCategory('cat17-18')">17~18元混搭區</button>
                <button class="tab-btn" onclick="switchCategory('cat20')">20元高吉/雙餡區</button>
                <button class="tab-btn" onclick="switchCategory('cat21-25')">21~25元奢華區</button>
            </div>

            <div class="flavor-scroll-area" id="flavorScrollArea">
                </div>

            <div class="classic-hr"></div>

            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                <span class="form-label" style="margin: 0;">個人本次契約小計：</span>
                <span style="font-size: 26px; font-weight: bold; color: var(--gold);" id="singleTotal">$ 0</span>
            </div>

            <button class="magic-btn" onclick="submitOrder()">送出訂單 ✦ 複製文字並記入帳本</button>
        </div>

        <div class="sidebar-panel" id="sidebarPanel">
            <h3 class="sidebar-title">🔮 全體吃貨契約秘典</h3>
            <p class="sidebar-desc">集結整座大廳同事渴望的總金流與口味總數。</p>
            
            <div class="ledger-list" id="ledgerList">
                <div style="text-align: center; padding: 40px 0; color: rgba(216,191,138,0.3); font-style: italic; font-size: 13px;">
                    大帳本空空如也，等待吃貨降臨...
                </div>
            </div>

            <div class="summary-box">
                <div class="summary-row" style="align-items: flex-start;">
                    <span style="color: #a897c9; white-space: nowrap;">全體口味加總：</span>
                    <span id="allFlavorStats" style="font-size: 12px; text-align: right; max-width: 220px; word-break: break-all; color: #fff; line-height: 1.4;">無</span>
                </div>
                <div class="summary-row" style="margin-top: 10px; padding-top: 8px; border-top: 1px dashed rgba(216,191,138,0.2);">
                    <span class="color-gold" style="font-weight: bold;">整單應付總金額：</span>
                    <span class="color-gold" style="font-size: 22px; font-weight: bold;" id="grandTotal">$ 0</span>
                </div>
            </div>

            <button class="magic-btn secondary-btn" style="margin-top: 12px; padding: 10px;" onclick="generateVisualCard()">生成大帳本結算圖卡 ✦</button>
        </div>

    </div>

    <div class="footer">
        <div class="footer-line"></div>
        <div class="footer-inner"><span>✦ 太極鰲訂購專線：0953-118-118 ✦</span></div>
        <div class="creator">Crafted with wheel cake alchemy & ledger magic</div>
    </div>
</div>

<div class="toast" id="toastBox"></div>
<canvas id="captureCanvas" width="450" height="650"></canvas>

<script>
/* ===== 星空背景生成 ===== */
const stars = document.getElementById("stars");
for (let i = 0; i < 140; i++) {
    const star = document.createElement("div");
    star.className = "star";
    star.style.left = Math.random() * 100 + "%";
    star.style.top = Math.random() * 100 + "%";
    star.style.animationDelay = Math.random() * 4 + "s";
    stars.appendChild(star);
}

/* ===== 縮放字體 ===== */
function changeFontSize(size, btnElement) {
    const root = document.documentElement;
    document.querySelectorAll('.font-btn').forEach(btn => btn.classList.remove('active'));
    btnElement.classList.add('active');
    if (size === 'small') root.style.setProperty('--base-font-size', '13px');
    else if (size === 'medium') root.style.setProperty('--base-font-size', '16px');
    else if (size === 'large') root.style.setProperty('--base-font-size', '20px');
}

/* =========================================================
   🥞 太極鰲完整菜單結構資料庫 (完美對照圖片上所有口味)
   ========================================================= */
const menuData = {
    cat15: [
        { id: 'm1', name: '紅豆', price: 15 },
        { id: 'm2', name: '奶油', price: 15 },
        { id: 'm3', name: '花生', price: 15 },
        { id: 'm4', name: '巧克力', price: 15 },
        { id: 'm5', name: '咖啡克林姆', price: 15 },
        { id: 'm6', name: '玉米哈蜜瓜奶', price: 15 },
        { id: 'm7', name: '草莓奶', price: 15 },
        { id: 'm8', name: '起士', price: 15 },
        { id: 'm9', name: '胡椒蛋', price: 15 },
        { id: 'm10', name: '蘿蔔絲', price: 15 },
        { id: 'm11', name: '酸菜脯', price: 15 },
        { id: 'm12', name: '高麗菜飯', price: 15 }
    ],
    'cat17-18': [
        { id: 'm13', name: '芝麻餡', price: 17 },
        { id: 'm14', name: '雙餡', price: 18 },
        { id: 'm15', name: '奧利奧 OREO', price: 18 }
    ],
    cat20: [
        { id: 'm16', name: '地瓜餡', price: 20 },
        { id: 'm17', name: '三味吉(麻吉+任選2口味)', price: 20 },
        { id: 'm18', name: '原味麻吉', price: 20 },
        { id: 'm19', name: '黑糖麻吉', price: 20 },
        { id: 'm20', name: '紅豆麻吉吉', price: 20 },
        { id: 'm21', name: '奶油麻吉吉', price: 20 },
        { id: 'm22', name: '花生麻吉吉', price: 20 },
        { id: 'm23', name: '芝麻麻吉吉', price: 20 }
    ],
    'cat21-25': [
        { id: 'm24', name: '巧克力麻吉吉', price: 21 },
        { id: 'm25', name: '起司蛋', price: 21 },
        { id: 'm26', name: '芋頭餡', price: 25 },
        { id: 'm27', name: '五餡', price: 25 }
    ]
};

let currentSelection = {};
let globalLedger = [];

// 一網打盡所有口味並初始化數量為0
function initSelections() {
    Object.keys(menuData).forEach(cat => {
        menuData[cat].forEach(item => {
            currentSelection[item.id] = 0;
        });
    });
}

// 動態渲染介面上的口味格子
function renderFlavorLists() {
    const scrollArea = document.getElementById('flavorScrollArea');
    scrollArea.innerHTML = '';

    Object.keys(menuData).forEach((cat, idx) => {
        const pane = document.createElement('div');
        pane.className = `flavor-group-pane ${idx === 0 ? 'active' : ''}`;
        pane.id = `pane-${cat}`;

        menuData[cat].forEach(item => {
            const row = document.createElement('div');
            row.className = 'flavor-row';
            row.innerHTML = `
                <div class="flavor-info">
                    <span class="flavor-name">${item.name}</span>
                    <span class="flavor-price">$ ${item.price} / 個</span>
                </div>
                <div class="counter-controls">
                    <button class="counter-btn" type="button" onclick="updateCount('${item.id}', -1)">-</button>
                    <span class="counter-value" id="count-${item.id}">0</span>
                    <button class="counter-btn" type="button" onclick="updateCount('${item.id}', 1)">+</button>
                </div>
            `;
            pane.appendChild(row);
        });
        scrollArea.appendChild(pane);
    });
}

// 切換頁籤分流
function switchCategory(catId) {
    document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
    event.target.classList.add('active');

    document.querySelectorAll('.flavor-group-pane').forEach(pane => pane.classList.remove('active'));
    document.getElementById(`pane-${catId}`).classList.add('active');
}

// 增減單個口味按鈕數量
function updateCount(id, delta) {
    const newVal = currentSelection[id] + delta;
    if (newVal >= 0 && newVal <= 99) {
        currentSelection[id] = newVal;
        document.getElementById(`count-${id}`).textContent = newVal;
        calculateSingleTotal();
    }
}

// 計算當前個人的點餐小計
function findItemById(id) {
    for (let cat of Object.keys(menuData)) {
        let match = menuData[cat].find(i => i.id === id);
        if (match) return match;
    }
    return null;
}

function calculateSingleTotal() {
    let sum = 0;
    Object.keys(currentSelection).forEach(id => {
        const qty = currentSelection[id];
        const item = findItemById(id);
        if (item && qty > 0) {
            sum += qty * item.price;
        }
    });
    document.getElementById('singleTotal').textContent = `$ ${sum}`;
    return sum;
}

function showToast(msg) {
    const toast = document.getElementById('toastBox');
    toast.textContent = msg;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 2500);
}

// 同事點完按確定
function submitOrder() {
    const name = document.getElementById('memberInput').value.trim();
    if (!name) {
        showToast('🔮 請先輸入您的名字，大帳本才不會變成無頭公案！');
        return;
    }

    let hasItems = false;
    let detailSegments = [];
    let itemsOrdered = {};

    Object.keys(currentSelection).forEach(id => {
        const qty = currentSelection[id];
        if (qty > 0) {
            hasItems = true;
            const item = findItemById(id);
            detailSegments.push(`${item.name} x${qty}`);
            itemsOrdered[id] = qty;
        }
    });

    if (!hasItems) {
        showToast('🔮 您還沒選擇任何車輪餅口味喔！');
        return;
    }

    const cost = calculateSingleTotal();
    const copyText = `✦ 太極鰲登記 ✦ 【${name}】${detailSegments.join(', ')}，共 ${cost} 元`;

    // 歷史紀錄寫入全域
    globalLedger.push({
        id: Date.now(),
        name: name,
        detailsText: detailSegments.join(', '),
        items: itemsOrdered,
        cost: cost
    });

    // 複製文字至剪貼簿
    navigator.clipboard.writeText(copyText).then(() => {
        showToast(`✨ 送出成功！【${name}】的點餐文字已自動複製，可直接貼到 LINE 核對！`);
    }).catch(() => {
        showToast(`✨ 已成功記錄到右側大帳本！`);
    });

    // 重設表單與數量
    document.getElementById('memberInput').value = '';
    Object.keys(currentSelection).forEach(id => {
        currentSelection[id] = 0;
        const element = document.getElementById(`count-${id}`);
        if(element) element.textContent = '0';
    });
    calculateSingleTotal();

    renderLedger();
}

function removeRecord(id) {
    globalLedger = globalLedger.filter(rec => rec.id !== id);
    renderLedger();
    showToast('🔮 已將該筆點餐資料從秘典中抹除');
}

// 統整全辦公室的所有訂購資料
function renderLedger() {
    const listContainer = document.getElementById('ledgerList');
    if (globalLedger.length === 0) {
        listContainer.innerHTML = `
            <div style="text-align: center; padding: 40px 0; color: rgba(216,191,138,0.3); font-style: italic; font-size: 13px;">
                大帳本空空如也，等待吃貨降臨...
            </div>
        `;
        document.getElementById('allFlavorStats').textContent = '無';
        document.getElementById('grandTotal').textContent = '$ 0';
        return;
    }

    listContainer.innerHTML = '';
    let totalMoney = 0;
    let totalFlavorCounters = {};

    globalLedger.forEach(record => {
        totalMoney += record.cost;
        
        Object.keys(record.items).forEach(id => {
            totalFlavorCounters[id] = (totalFlavorCounters[id] || 0) + record.items[id];
        });

        const div = document.createElement('div');
        div.className = 'ledger-item';
        div.innerHTML = `
            <div>
                <span class="ledger-name">【${record.name}】</span>
                <span class="ledger-detail">${record.detailsText}</span>
            </div>
            <div style="display: flex; align-items: center; white-space:nowrap;">
                <span class="color-mint" style="font-weight:600;">$${record.cost}</span>
                <span class="delete-record" onclick="removeRecord(${record.id})">✕</span>
            </div>
        `;
        listContainer.appendChild(div);
    });

    document.getElementById('grandTotal').textContent = `$ ${totalMoney}`;

    // 格式化口味大加總文字
    let statSegments = [];
    Object.keys(totalFlavorCounters).forEach(id => {
        const item = findItemById(id);
        if (item && totalFlavorCounters[id] > 0) {
            statSegments.push(`${item.name}:${totalFlavorCounters[id]}個`);
        }
    });
    document.getElementById('allFlavorStats').textContent = statSegments.length > 0 ? statSegments.join(' / ') : '無';
}

/* =========================================================
   🎨 畫布渲染：生成一目了然的太極鰲車輪餅大總結圖卡
   ========================================================= */
function generateVisualCard() {
    if (globalLedger.length === 0) {
        showToast('🔮 目前無任何統計數據，無法凝結成圖卡！');
        return;
    }

    const canvas = document.getElementById('captureCanvas');
    const ctx = canvas.getContext('2d');

    // 1. 魔法漸層背景
    let gradient = ctx.createLinearGradient(0, 0, 0, canvas.height);
    gradient.addColorStop(0, '#171320');
    gradient.addColorStop(0.5, '#241a35');
    gradient.addColorStop(1, '#31244d');
    ctx.fillStyle = gradient;
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    // 星芒
    ctx.fillStyle = "rgba(255, 255, 255, 0.5)";
    for (let i = 0; i < 45; i++) {
        ctx.fillRect(Math.random() * canvas.width, Math.random() * canvas.height, 1.5, 1.5);
    }

    // 2. 金屬古典雙框
    ctx.strokeStyle = '#d8bf8a'; ctx.lineWidth = 2; ctx.strokeRect(15, 15, canvas.width - 30, canvas.height - 30);
    ctx.strokeStyle = 'rgba(216, 191, 138, 0.2)'; ctx.lineWidth = 1; ctx.strokeRect(20, 20, canvas.width - 40, canvas.height - 40);

    // 四角裝飾
    ctx.fillStyle = '#d8bf8a'; ctx.font = '16px serif';
    ctx.fillText('✦', 25, 38); ctx.fillText('✦', canvas.width - 40, 38);
    ctx.fillText('✦', 25, canvas.height - 25); ctx.fillText('✦', canvas.width - 40, canvas.height - 25);

    // 3. 大標題
    ctx.textAlign = 'center';
    ctx.font = 'bold 22px "Microsoft JhengHei"';
    ctx.fillStyle = '#ffffff';
    ctx.fillText('🥞 太極鰲車輪餅．總結算單 🥞', canvas.width / 2, 65);

    // 分隔金線
    let lineGrad = ctx.createLinearGradient(60, 0, canvas.width - 60, 0);
    lineGrad.addColorStop(0, 'transparent'); lineGrad.addColorStop(0.5, '#d8bf8a'); lineGrad.addColorStop(1, 'transparent');
    ctx.fillStyle = lineGrad; ctx.fillRect(60, 82, canvas.width - 120, 1);

    // 4. 渲染名單明細
    ctx.textAlign = 'left';
    let currentY = 120;

    globalLedger.forEach((record) => {
        if (currentY > canvas.height - 160) return; // 超出高度限制則不再繪製

        // 同事尊稱
        ctx.font = 'bold 14px "Microsoft JhengHei"'; ctx.fillStyle = '#d8bf8a';
        ctx.fillText(`【${record.name}】`, 35, currentY);

        // 品項內容
        ctx.font = '13px "Microsoft JhengHei"'; ctx.fillStyle = '#eadfff';
        let txt = record.detailsText;
        if(txt.length > 25) txt = txt.substring(0, 23) + '...';
        ctx.fillText(txt, 115, currentY);

        // 金額
        ctx.textAlign = 'right';
        ctx.font = 'bold 14px monospace'; ctx.fillStyle = '#8ae0be';
        ctx.fillText(`$${record.cost}`, canvas.width - 35, currentY);
        ctx.textAlign = 'left';

        // 點狀分隔線
        ctx.strokeStyle = 'rgba(216, 191, 138, 0.1)'; ctx.lineWidth = 1;
        ctx.beginPath(); ctx.moveTo(35, currentY + 10); ctx.lineTo(canvas.width - 35, currentY + 10); ctx.stroke();

        currentY += 34;
    });

    // 5. 底部總結黑盒子
    ctx.fillStyle = 'rgba(216, 191, 138, 0.07)';
    ctx.fillRect(35, canvas.height - 130, canvas.width - 70, 90);
    ctx.strokeStyle = 'rgba(216, 191, 138, 0.3)';
    ctx.strokeRect(35, canvas.height - 130, canvas.width - 70, 90);

    // 口味加總
    ctx.font = '12px "Microsoft JhengHei"'; ctx.fillStyle = '#a897c9';
    ctx.fillText('全體品項統計：', 45, canvas.height - 105);

    ctx.font = '12px "Microsoft JhengHei"'; ctx.fillStyle = '#ffffff';
    let allStats = document.getElementById('allFlavorStats').textContent;
    
    // 如果品項字串太長，進行分段或截斷，避免字體溢出圖卡
    if(allStats.length > 34) {
        ctx.fillText(allStats.substring(0, 32) + '...', 135, canvas.height - 105);
    } else {
        ctx.fillText(allStats, 135, canvas.height - 105);
    }

    // 總金額統計
    ctx.font = 'bold 15px "Microsoft JhengHei"'; ctx.fillStyle = '#d8bf8a';
    ctx.fillText('本次訂購應付總計：', 45, canvas.height - 65);

    ctx.textAlign = 'right';
    ctx.font = 'bold 24px monospace'; ctx.fillStyle = '#d8bf8a';
    ctx.fillText(document.getElementById('grandTotal').textContent, canvas.width - 45, canvas.height - 65);

    // 6. 觸發原生瀏覽器下載
    setTimeout(() => {
        const dataURL = canvas.toDataURL("image/png");
        const link = document.createElement('a');
        link.download = `太極鰲車輪餅結算單_${new Date().toLocaleDateString()}.png`;
        link.href = dataURL;
        link.click();
        showToast('🎨 結算大圖卡已成功轉化並下載至您的裝置中！');
    }, 200);
}

// 初始啟動
window.onload = function() {
    initSelections();
    renderFlavorLists();
};
</script>

