<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🥞 太極鰲車輪餅．美味結算工坊</title>

    <meta name="robots" content="noindex,nofollow,noarchive,nosnippet,noimageindex">
    <meta name="googlebot" content="noindex,nofollow,noarchive,nosnippet,noimageindex">
    <meta name="bingbot" content="noindex,nofollow,noarchive,nosnippet,noimageindex">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@500;700&family=Zen+Maru+Gothic:wght@500;700&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            transition: font-size 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
        }

        :root {
            --bg-base: #fff9f6; 
            --bg-gradient-end: #ffebe3; 
            --card-bg: #ffffff; 
            --text-main: #54433a; 
            --text-sub: #8e7a70; 
            --flavor-bg: #fffbf9; 
            --butter-gold: #f6c86c; 
            --butter-gold-hover: #f3b946;
            --mint-green: #7ecbb4;
            --berry-pink: #f79999;
            --base-font-size: 16px;
        }

        body {
            min-height: 100vh;
            color: var(--text-main);
            font-family: "Zen Maru Gothic", "Quicksand", "Microsoft JhengHei", sans-serif;
            background: linear-gradient(180deg, var(--bg-base) 0%, var(--bg-gradient-end) 100%);
            padding: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .decor-border {
            position: fixed;
            inset: 12px;
            border: 2px dashed rgba(142, 122, 112, 0.15);
            border-radius: 24px;
            pointer-events: none;
            z-index: 999;
        }

        .container {
            width: 100%;
            max-width: 1040px;
            margin: auto;
            position: relative;
            z-index: 2;
            padding: 10px 0;
        }

        .font-control {
            display: flex;
            justify-content: flex-end;
            gap: 8px;
            margin-bottom: 12px;
        }

        .font-btn {
            background: var(--card-bg);
            border: 1px solid rgba(142, 122, 112, 0.2);
            color: var(--text-main);
            padding: 6px 14px;
            border-radius: 30px;
            cursor: pointer;
            font-size: 13px;
            font-weight: bold;
            box-shadow: 0 2px 6px rgba(0,0,0,0.03);
        }

        .font-btn:hover {
            background: #fff5f0;
            border-color: var(--butter-gold);
        }

        .font-btn.active {
            background: var(--butter-gold);
            color: var(--text-main);
            border-color: var(--butter-gold);
            box-shadow: 0 2px 8px rgba(246, 200, 108, 0.4);
        }

        .title-block {
            text-align: center;
            margin-bottom: 30px;
        }

        .main-title {
            font-size: clamp(24px, 4.5vw, 36px);
            font-weight: 700;
            color: var(--text-main);
            letter-spacing: 1px;
            line-height: 1.4;
        }

        .title-badge {
            display: inline-block;
            background: rgba(246, 200, 108, 0.2);
            color: #bd8619;
            font-size: 13px;
            padding: 4px 12px;
            border-radius: 20px;
            margin-bottom: 8px;
            font-weight: 700;
        }

        .layout-grid {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }
        @media (min-width: 950px) {
            .layout-grid { flex-direction: row; align-items: stretch; }
        }

        .main-calculator, .sidebar-panel {
            background: var(--card-bg);
            border: 1px solid rgba(142, 122, 112, 0.12);
            border-radius: 24px;
            padding: 28px;
            box-shadow: 0 10px 30px rgba(84, 67, 58, 0.05);
            display: flex;
            flex-direction: column;
        }
        @media (min-width: 950px) {
            .sidebar-panel { width: 380px; }
        }

        .form-label {
            display: block;
            font-size: calc(var(--base-font-size) * 0.9);
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 8px;
        }

        .form-group { margin-bottom: 20px; }
        
        .classic-input {
            width: 100%;
            background: #fffbf9;
            border: 1.5px solid rgba(142, 122, 112, 0.18);
            border-radius: 14px;
            padding: 12px 16px;
            color: var(--text-main);
            font-size: calc(var(--base-font-size) * 1.0);
            font-family: inherit;
        }
        .classic-input:focus {
            outline: none;
            border-color: var(--butter-gold);
            background: #ffffff;
            box-shadow: 0 0 0 3px rgba(246, 200, 108, 0.25);
        }

        .category-tabs {
            display: flex;
            gap: 6px;
            margin-bottom: 16px;
            overflow-x: auto;
            padding-bottom: 4px;
        }
        .tab-btn {
            background: #f7f3f0;
            border: 1px solid transparent;
            color: var(--text-sub);
            padding: 8px 14px;
            border-radius: 12px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 700;
            white-space: nowrap;
            font-family: inherit;
        }
        .tab-btn:hover { color: var(--text-main); background: #eee7e2; }
        .tab-btn.active {
            background: #fff4dd;
            border-color: rgba(246, 200, 108, 0.5);
            color: #b07910;
        }

        .flavor-scroll-area { max-height: 380px; overflow-y: auto; padding-right: 4px; margin-bottom: 15px; }
        .flavor-group-pane { display: none; }
        .flavor-group-pane.active { display: block; }

        .flavor-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--flavor-bg);
            padding: 12px 16px;
            border-radius: 16px;
            margin-bottom: 8px;
            border: 1px solid rgba(142, 122, 112, 0.06);
        }
        .flavor-name { font-size: calc(var(--base-font-size) * 0.95); color: var(--text-main); font-weight: 700; }
        .flavor-price { font-size: 12px; color: var(--text-sub); margin-top: 1px; }

        .counter-controls { display: flex; align-items: center; gap: 12px; }
        .counter-btn {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 1.5px solid rgba(142, 122, 112, 0.2);
            background: #ffffff;
            color: var(--text-main);
            cursor: pointer;
            font-size: 15px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .counter-btn:hover { border-color: var(--butter-gold); background: #fffdf9; color: var(--butter-gold-hover); }
        .counter-value { font-size: calc(var(--base-font-size) * 1.0); font-weight: 700; width: 20px; text-align: center; color: var(--text-main); }

        .magic-btn {
            width: 100%;
            background: var(--butter-gold);
            border: none;
            color: var(--text-main);
            padding: 14px;
            border-radius: 16px;
            cursor: pointer;
            font-family: inherit;
            font-weight: 700;
            font-size: calc(var(--base-font-size) * 1.0);
            box-shadow: 0 4px 12px rgba(246, 200, 108, 0.3);
            margin-top: auto;
        }
        .magic-btn:hover {
            background: var(--butter-gold-hover);
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(246, 200, 108, 0.4);
        }
        .secondary-btn {
            background: #fffcf7;
            border: 1.5px solid var(--butter-gold);
            color: var(--text-main);
            box-shadow: none;
        }
        .secondary-btn:hover { background: #fff7e6; transform: none; box-shadow: none; }

        .ledger-list { max-height: 280px; overflow-y: auto; margin-bottom: 15px; padding-right: 4px; }
        .ledger-item { padding: 12px 0; border-bottom: 1px dashed rgba(142, 122, 112, 0.15); font-size: calc(var(--base-font-size) * 0.85); display: flex; justify-content: space-between; align-items: center; }
        .ledger-name { color: var(--text-main); font-weight: 700; }
        .ledger-detail { color: var(--text-sub); }
        .delete-record { color: var(--berry-pink); cursor: pointer; margin-left: 10px; font-size: 13px; font-weight: 700; }

        .summary-box { background: #fffbf5; border: 1.5px solid rgba(246, 200, 108, 0.3); border-radius: 16px; padding: 14px; margin-top: auto; }
        .summary-row { display: flex; justify-content: space-between; margin-bottom: 6px; font-size: calc(var(--base-font-size) * 0.9); }
        .smooth-hr { margin: 18px 0; border: none; height: 1px; background: rgba(142, 122, 112, 0.12); }

        .sidebar-title { font-size: calc(var(--base-font-size) * 1.1); font-weight: 700; color: var(--text-main); text-align: center; margin-bottom: 4px; }
        .sidebar-desc { font-size: 12px; color: var(--text-sub); text-align: center; margin-bottom: 16px; }

        .toast { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%) translateY(100px); background: #4a3b32; color: #ffffff; padding: 12px 24px; border-radius: 12px; z-index: 2000; opacity: 0; transition: all 0.3s ease; font-size: 14px; box-shadow: 0 8px 24px rgba(0,0,0,0.15); text-align: center; }
        .toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }

        .price-color { color: #d96a6a; font-weight: 700; }
        #captureCanvas { display: none; }

        .footer { text-align: center; margin-top: 35px; color: var(--text-sub); font-size: 13px; }
        .footer-inner { margin-bottom: 4px; font-weight: 700; color: var(--text-main); }
    </style>
</head>
<body>

<div class="decor-border"></div>

<div class="container">
    <div class="font-control">
        <button class="font-btn" onclick="changeFontSize('small', this)">A -</button>
        <button class="font-btn active" onclick="changeFontSize('medium', this)">A</button>
        <button class="font-btn" onclick="changeFontSize('large', this)">A +</button>
    </div>

    <div class="title-block">
        <div class="title-badge">下午茶開團應援 🥞</div>
        <h1 class="main-title">太極鰲車輪餅<br>辦公室美味結算工坊</h1>
    </div>

    <div class="layout-grid">
        <div class="main-calculator" id="mainCorePanel">
            <div class="form-group">
                <label class="form-label">Step 1. 輸入你的名字或暱稱</label>
                <input type="text" id="memberInput" class="classic-input" placeholder="請輸入名字，主揪才找得到人喔..." autocomplete="off">
            </div>

            <label class="form-label">Step 2. 選擇口味與數量（點擊分流切換價格區）</label>
            
            <div class="category-tabs" id="tabBar">
                <button class="tab-btn active" onclick="switchCategory('cat15')">15元傳統經典</button>
                <button class="tab-btn" onclick="switchCategory('cat17-18')">17~18元雙餡混搭</button>
                <button class="tab-btn" onclick="switchCategory('cat20')">20元高吉麻吉</button>
                <button class="tab-btn" onclick="switchCategory('cat21-25')">21~25元奢華多餡</button>
            </div>

            <div class="flavor-scroll-area" id="flavorScrollArea">
                </div>

            <div class="smooth-hr"></div>

            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                <span class="form-label" style="margin: 0;">您的本次點餐小計：</span>
                <span style="font-size: 26px; font-weight: 700; color: #d96a6a;" id="singleTotal">$ 0</span>
            </div>

            <button class="magic-btn" onclick="submitOrder()">送出點餐 ✦ 自動複製並寫入帳本</button>
        </div>

        <div class="sidebar-panel" id="sidebarPanel">
            <h3 class="sidebar-title">📋 今日全體點餐明細大帳本</h3>
            <p class="sidebar-desc">全辦公室目前已匯整的車輪餅願望清單。</p>
            
            <div class="ledger-list" id="ledgerList">
                <div style="text-align: center; padding: 40px 0; color: var(--text-sub); font-size: 13px;">
                    還沒有人點餐唷，快來當第一個！
                </div>
            </div>

            <div class="summary-box">
                <div class="summary-row" style="align-items: flex-start;">
                    <span style="color: var(--text-sub); white-space: nowrap;">全體口味統計：</span>
                    <span id="allFlavorStats" style="font-size: 12px; text-align: right; max-width: 210px; word-break: break-all; color: var(--text-main); font-weight: 700; line-height: 1.4;">無</span>
                </div>
                <div class="summary-row" style="margin-top: 10px; padding-top: 10px; border-top: 1px dashed rgba(142,122,112,0.2);">
                    <span style="font-weight: 700; color: var(--text-main);">整單應付總金額：</span>
                    <span style="font-size: 22px; font-weight: 700; color: #d96a6a;" id="grandTotal">$ 0</span>
                </div>
            </div>

            <button class="magic-btn secondary-btn" style="margin-top: 12px; padding: 10px;" onclick="generateVisualCard()">下載今日結算圖卡 📷</button>
        </div>
    </div>

    <div class="footer">
        <div class="footer-inner">✦ 太極鰲車輪餅訂購專線：0953-118-118 ✦</div>
        <div>美味下午茶神隊友 · 輕鬆結算不燒腦</div>
    </div>
</div>

<div class="toast" id="toastBox"></div>
<canvas id="captureCanvas" width="450" height="650"></canvas>

<script>
function changeFontSize(size, btnElement) {
    const root = document.documentElement;
    document.querySelectorAll('.font-btn').forEach(btn => btn.classList.remove('active'));
    btnElement.classList.add('active');
    if (size === 'small') root.style.setProperty('--base-font-size', '13px');
    else if (size === 'medium') root.style.setProperty('--base-font-size', '16px');
    else if (size === 'large') root.style.setProperty('--base-font-size', '20px');
}

const menuData = {
    cat15: [
        { id: 'm1', name: '紅豆', price: 15 },
        { id: 'm2', name: '奶油', price: 15 },
        { id: 'm3', name: '花生', price: 15 },
        { id: 'm4', name: '巧克力', price: 15 },
        { id: 'm5', name: '咖啡克林姆', price: 15 },
        { id: 'm6', name: '玉米哈蜜瓜奶', price: 15 },
        { id: 'm7', name: '草莓奶', price: 15 },
        { id: 'm8', name: '起士', price: 15 },
        { id: 'm9', name: '胡椒蛋', price: 15 },
        { id: 'm10', name: '蘿蔔絲', price: 15 },
        { id: 'm11', name: '酸菜脯', price: 15 },
        { id: 'm12', name: '高麗菜飯', price: 15 }
    ],
    'cat17-18': [
        { id: 'm13', name: '芝麻餡', price: 17 },
        { id: 'm14', name: '雙餡', price: 18 },
        { id: 'm15', name: '奧利奧 OREO', price: 18 }
    ],
    cat20: [
        { id: 'm16', name: '地瓜餡', price: 20 },
        { id: 'm17', name: '三味吉(麻吉+任選2口味)', price: 20 },
        { id: 'm18', name: '原味麻吉', price: 20 },
        { id: 'm19', name: '黑糖麻吉', price: 20 },
        { id: 'm20', name: '紅豆麻吉吉', price: 20 },
        { id: 'm21', name: '奶油麻吉吉', price: 20 },
        { id: 'm22', name: '花生麻吉吉', price: 20 },
        { id: 'm23', name: '芝麻麻吉吉', price: 20 }
    ],
    'cat21-25': [
        { id: 'm24', name: '巧克力麻吉吉', price: 21 },
        { id: 'm25', name: '起司蛋', price: 21 },
        { id: 'm26', name: '芋頭餡', price: 25 },
        { id: 'm27', name: '五餡', price: 25 }
    ]
};

let currentSelection = {};
let globalLedger = [];

function initSelections() {
    Object.keys(menuData).forEach(cat => {
        menuData[cat].forEach(item => { currentSelection[item.id] = 0; });
    });
}

function renderFlavorLists() {
    const scrollArea = document.getElementById('flavorScrollArea');
    scrollArea.innerHTML = '';

    Object.keys(menuData).forEach((cat, idx) => {
        const pane = document.createElement('div');
        pane.className = `flavor-group-pane ${idx === 0 ? 'active' : ''}`;
        pane.id = `pane-${cat}`;

        menuData[cat].forEach(item => {
            const row = document.createElement('div');
            row.className = 'flavor-row';
            row.innerHTML = `
                <div class="flavor-info">
                    <span class="flavor-name">${item.name}</span>
                    <span class="flavor-price">$ ${item.price} / 個</span>
                </div>
                <div class="counter-controls">
                    <button class="counter-btn" type="button" onclick="updateCount('${item.id}', -1)">-</button>
                    <span class="counter-value" id="count-${item.id}">0</span>
                    <button class="counter-btn" type="button" onclick="updateCount('${item.id}', 1)">+</button>
                </div>
            `;
            pane.appendChild(row);
        });
        scrollArea.appendChild(pane);
    });
}

function switchCategory(catId) {
    if (event) {
        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
        event.target.classList.add('active');
    }
    document.querySelectorAll('.flavor-group-pane').forEach(pane => pane.classList.remove('active'));
    document.getElementById(`pane-${catId}`).classList.add('active');
}

function updateCount(id, delta) {
    const newVal = currentSelection[id] + delta;
    if (newVal >= 0 && newVal <= 99) {
        currentSelection[id] = newVal;
        document.getElementById(`count-${id}`).textContent = newVal;
        calculateSingleTotal();
    }
}

function findItemById(id) {
    for (let cat of Object.keys(menuData)) {
        let match = menuData[cat].find(i => i.id === id);
        if (match) return match;
    }
    return null;
}

function calculateSingleTotal() {
    let sum = 0;
    Object.keys(currentSelection).forEach(id => {
        const qty = currentSelection[id];
        const item = findItemById(id);
        if (item && qty > 0) sum += qty * item.price;
    });
    document.getElementById('singleTotal').textContent = `$ ${sum}`;
    return sum;
}

function showToast(msg) {
    const toast = document.getElementById('toastBox');
    toast.textContent = msg;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 2500);
}

function submitOrder() {
    const name = document.getElementById('memberInput').value.trim();
    if (!name) {
        showToast('🥞 請先填寫名字，方便主揪核對唷！');
        return;
    }

    let hasItems = false;
    let detailSegments = [];
    let itemsOrdered = {};

    Object.keys(currentSelection).forEach(id => {
        const qty = currentSelection[id];
        if (qty > 0) {
            hasItems = true;
            const item = findItemById(id);
            detailSegments.push(`${item.name} x${qty}`);
            itemsOrdered[id] = qty;
        }
    });

    if (!hasItems) {
        showToast('🥞 勾選一下你想吃的車輪餅口味吧！');
        return;
    }

    const cost = calculateSingleTotal();
    const copyText = `🥞 太極鰲車輪餅 🥞\n【${name}】${detailSegments.join(', ')}，合計 ${cost} 元`;

    globalLedger.push({
        id: Date.now(),
        name: name,
        detailsText: detailSegments.join(', '),
        items: itemsOrdered,
        cost: cost
    });

    navigator.clipboard.writeText(copyText).then(() => {
        showToast(`✨ 送出成功！【${name}】的點餐細節已複製，快去 LINE 群貼給主揪吧！`);
    }).catch(() => {
        showToast(`✨ 點餐成功！已記入右側公用明細大帳本！`);
    });

    document.getElementById('memberInput').value = '';
    Object.keys(currentSelection).forEach(id => {
        currentSelection[id] = 0;
        const element = document.getElementById(`count-${id}`);
        if(element) element.textContent = '0';
    });
    calculateSingleTotal();
    renderLedger();
}

function removeRecord(id) {
    globalLedger = globalLedger.filter(rec => rec.id !== id);
    renderLedger();
    showToast('💡 已將該筆點餐明細自帳本中移除');
}

function renderLedger() {
    const listContainer = document.getElementById('ledgerList');
    if (globalLedger.length === 0) {
        listContainer.innerHTML = `
            <div style="text-align: center; padding: 40px 0; color: var(--text-sub); font-size: 13px;">
                還沒有人點餐唷，快來當第一個！
            </div>
        `;
        document.getElementById('allFlavorStats').textContent = '無';
        document.getElementById('grandTotal').textContent = '$ 0';
        return;
    }

    listContainer.innerHTML = '';
    let totalMoney = 0;
    let totalFlavorCounters = {};

    globalLedger.forEach(record => {
        totalMoney += record.cost;
        Object.keys(record.items).forEach(id => {
            totalFlavorCounters[id] = (totalFlavorCounters[id] || 0) + record.items[id];
        });

        const div = document.createElement('div');
        div.className = 'ledger-item';
        div.innerHTML = `
            <div>
                <span class="ledger-name">【${record.name}】</span>
                <span class="ledger-detail">${record.detailsText}</span>
            </div>
            <div style="display: flex; align-items: center; white-space:nowrap;">
                <span class="price-color">$${record.cost}</span>
                <span class="delete-record" onclick="removeRecord(${record.id})">✕</span>
            </div>
        `;
        listContainer.appendChild(div);
    });

    document.getElementById('grandTotal').textContent = `$ ${totalMoney}`;

    let statSegments = [];
    Object.keys(totalFlavorCounters).forEach(id => {
        const item = findItemById(id);
        if (item && totalFlavorCounters[id] > 0) {
            statSegments.push(`${item.name}:${totalFlavorCounters[id]}個`);
        }
    });
    document.getElementById('allFlavorStats').textContent = statSegments.length > 0 ? statSegments.join(' / ') : '無';
}

function generateVisualCard() {
    if (globalLedger.length === 0) {
        showToast('🥞 目前大帳本還沒有資料，無法生成結算圖卡唷！');
        return;
    }

    const canvas = document.getElementById('captureCanvas');
    const ctx = canvas.getContext('2d');

    let gradient = ctx.createLinearGradient(0, 0, 0, canvas.height);
    gradient.addColorStop(0, '#fff9f6');
    gradient.addColorStop(1, '#ffebe3');
    ctx.fillStyle = gradient;
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    ctx.strokeStyle = '#e3d6cf'; ctx.lineWidth = 2; ctx.strokeRect(15, 15, canvas.width - 30, canvas.height - 30);
    ctx.strokeStyle = 'rgba(246, 200, 108, 0.4)'; ctx.lineWidth = 1.5; ctx.strokeRect(20, 20, canvas.width - 40, canvas.height - 40);

    ctx.textAlign = 'center';
    ctx.font = 'bold 22px "Microsoft JhengHei", sans-serif';
    ctx.fillStyle = '#54433a';
    ctx.fillText('🥞 太極鰲車輪餅 · 下午茶結算單 🥞', canvas.width / 2, 65);

    ctx.strokeStyle = 'rgba(142, 122, 112, 0.2)';
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 4]);
    ctx.beginPath(); ctx.moveTo(40, 85); ctx.lineTo(canvas.width - 40, 85); ctx.stroke();
    ctx.setLineDash([]);

    ctx.textAlign = 'left';
    let currentY = 125;

    globalLedger.forEach((record) => {
        if (currentY > canvas.height - 150) return;

        ctx.font = 'bold 14px "Microsoft JhengHei", sans-serif'; ctx.fillStyle = '#54433a';
        ctx.fillText(`【${record.name}】`, 35, currentY);

        ctx.font = '13px "Microsoft JhengHei", sans-serif'; ctx.fillStyle = '#8e7a70';
        let txt = record.detailsText;
        if(txt.length > 25) txt = txt.substring(0, 23) + '...';
        ctx.fillText(txt, 115, currentY);

        ctx.textAlign = 'right';
        ctx.font = 'bold 15px "Quicksand", sans-serif'; ctx.fillStyle = '#d96a6a';
        ctx.fillText(`$${record.cost}`, canvas.width - 35, currentY);
        ctx.textAlign = 'left';

        ctx.strokeStyle = 'rgba(142, 122, 112, 0.08)'; ctx.lineWidth = 1;
        ctx.beginPath(); ctx.moveTo(35, currentY + 12); ctx.lineTo(canvas.width - 35, currentY + 12); ctx.stroke();

        currentY += 36;
    });

    ctx.fillStyle = '#ffffff';
    ctx.fillRect(35, canvas.height - 125, canvas.width - 70, 85);
    ctx.strokeStyle = 'rgba(246, 200, 108, 0.6)';
    ctx.lineWidth = 1.5;
    ctx.strokeRect(35, canvas.height - 125, canvas.width - 70, 85);

    ctx.font = 'bold 12px "Microsoft JhengHei", sans-serif'; ctx.fillStyle = '#8e7a70';
    ctx.fillText('全體品項統計：', 45, canvas.height - 95);

    ctx.font = '12px "Microsoft JhengHei", sans-serif'; ctx.fillStyle = '#54433a';
    let allStats = document.getElementById('allFlavorStats').textContent;
    if(allStats.length > 34) {
        ctx.fillText(allStats.substring(0, 32) + '...', 135, canvas.height - 95);
    } else {
        ctx.fillText(allStats, 135, canvas.height - 95);
    }

    ctx.font = 'bold 14px "Microsoft JhengHei", sans-serif'; ctx.fillStyle = '#54433a';
    ctx.fillText('今日開團總金額：', 45, canvas.height - 60);

    ctx.textAlign = 'right';
    ctx.font = 'bold 24px "Quicksand", sans-serif'; ctx.fillStyle = '#d96a6a';
    ctx.fillText(document.getElementById('grandTotal').textContent, canvas.width - 45, canvas.height - 60);

    setTimeout(() => {
        const dataURL = canvas.toDataURL("image/png");
        const link = document.createElement('a');
        link.download = `太極鰲車輪餅結算單_${new Date().toLocaleDateString()}.png`;
        link.href = dataURL;
        link.click();
        showToast('🎨 漂亮的粉彩結算圖卡已經下載完成囉！');
    }, 200);
}

window.onload = function() {
    initSelections();
    renderFlavorLists();
};
</script>

</body>
</html>
