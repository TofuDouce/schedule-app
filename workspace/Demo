<!DOCTYPE html>
<html lang="zh-Hant" data-theme="dark">

<head>

<meta charset="UTF-8">

<meta
name="viewport"
content="width=device-width, initial-scale=1.0">

<title>中正診所 Portal</title>

<meta
name="robots"
content="noindex,nofollow,noarchive,nosnippet">

<link rel="preconnect" href="https://fonts.googleapis.com">

<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link
href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Cinzel:wght@500;600&display=swap"
rel="stylesheet">

<style>

/* =========================
RESET
========================= */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html,
body{

    min-height:100%;

    overflow-x:hidden;

    font-family:
    "Inter",
    "Microsoft JhengHei",
    sans-serif;

    background:
    #060816;

    color:white;
}

/* =========================
背景光暈
========================= */

body::before{

    content:"";

    position:fixed;

    inset:0;

    z-index:-3;

    background:

    radial-gradient(
    circle at top left,
    rgba(124,58,237,.24),
    transparent 35%
    ),

    radial-gradient(
    circle at bottom right,
    rgba(59,130,246,.18),
    transparent 30%
    ),

    linear-gradient(
    180deg,
    #050816,
    #0b1020
    );
}

/* =========================
星空
========================= */

.stars{

    position:fixed;

    inset:0;

    z-index:-2;

    overflow:hidden;
}

.star{

    position:absolute;

    width:2px;
    height:2px;

    background:white;

    border-radius:50%;

    opacity:.35;

    animation:
    twinkle 5s infinite;
}

@keyframes twinkle{

    0%{
        opacity:.15;
    }

    50%{
        opacity:1;
    }

    100%{
        opacity:.15;
    }
}

/* =========================
慕夏邊框
========================= */

.frame{

    position:fixed;

    inset:16px;

    border-radius:36px;

    border:
    1px solid
    rgba(196,181,253,.12);

    pointer-events:none;

    z-index:50;
}

.frame::before{

    content:"";

    position:absolute;

    inset:12px;

    border-radius:28px;

    border:
    1px solid
    rgba(196,181,253,.07);
}

.corner{

    position:absolute;

    width:90px;
    height:90px;

    border:
    1px solid
    rgba(196,181,253,.12);
}

.corner::before{

    content:"";

    position:absolute;

    inset:12px;

    border-radius:50%;

    border:
    1px solid
    rgba(196,181,253,.08);
}

.tl{
    top:-1px;
    left:-1px;

    border-right:none;
    border-bottom:none;

    border-radius:36px 0 0 0;
}

.tr{
    top:-1px;
    right:-1px;

    border-left:none;
    border-bottom:none;

    border-radius:0 36px 0 0;
}

.bl{
    bottom:-1px;
    left:-1px;

    border-right:none;
    border-top:none;

    border-radius:0 0 0 36px;
}

.br{
    bottom:-1px;
    right:-1px;

    border-left:none;
    border-top:none;

    border-radius:0 0 36px 0;
}

/* =========================
MAIN
========================= */

.main{

    width:100%;

    max-width:1500px;

    margin:auto;

    padding:
    60px 34px 80px;
}

/* =========================
HEADER
========================= */

.header{

    display:flex;

    justify-content:space-between;

    align-items:flex-start;

    gap:40px;

    margin-bottom:60px;
}

/* =========================
TITLE
========================= */

.title-main{

    font-size:
    clamp(58px,8vw,96px);

    font-weight:900;

    line-height:1.02;

    letter-spacing:-4px;

    color:
    rgba(255,255,255,.95);
}

.title-sub{

    margin-top:8px;

    font-family:
    "Cinzel",
    serif;

    font-size:
    clamp(28px,4vw,52px);

    letter-spacing:10px;

    color:
    rgba(226,215,255,.72);
}

/* =========================
SUBTITLE
========================= */

.subtitle{

    margin-top:26px;

    font-size:
    clamp(22px,2.4vw,30px);

    line-height:1.9;

    color:
    rgba(226,232,240,.68);

    max-width:760px;
}

/* =========================
CLOCK
========================= */

.clock-area{

    text-align:right;
}

.clock{

    font-size:
    clamp(46px,7vw,74px);

    font-weight:800;

    letter-spacing:-2px;

    line-height:1;

    color:
    rgba(255,255,255,.92);
}

.date{

    margin-top:12px;

    font-size:
    clamp(18px,2vw,24px);

    color:
    rgba(226,232,240,.52);

    letter-spacing:1px;
}

/* =========================
SECTION
========================= */

.section{

    margin-bottom:56px;
}

.section-label{

    font-size:14px;

    letter-spacing:6px;

    color:
    rgba(196,181,253,.56);

    margin-bottom:26px;

    text-transform:uppercase;
}

/* =========================
GRID
========================= */

.grid{

    display:grid;

    grid-template-columns:
    repeat(
        auto-fit,
        minmax(320px,1fr)
    );

    gap:30px;
}

/* =========================
CARD
========================= */

.card{

    position:relative;

    min-height:320px;

    border-radius:32px;

    overflow:hidden;

    background:

    linear-gradient(
    180deg,
    rgba(20,25,40,.88),
    rgba(8,12,24,.96)
    );

    border:
    1px solid
    rgba(255,255,255,.06);

    transition:.35s;

    backdrop-filter:blur(20px);
}

.card:hover{

    transform:
    translateY(-8px);

    border-color:
    rgba(167,139,250,.35);

    box-shadow:

    0 20px 40px
    rgba(0,0,0,.35);
}

.card-link{

    display:block;

    height:100%;

    text-decoration:none;

    color:white;

    padding:36px;
}

.card-top{

    display:flex;

    justify-content:space-between;

    align-items:center;

    margin-bottom:28px;
}

/* =========================
ICON
========================= */

.icon-box{

    width:82px;
    height:82px;

    border-radius:28px;

    display:flex;

    align-items:center;

    justify-content:center;

    font-size:38px;

    background:

    linear-gradient(
    135deg,
    rgba(139,92,246,.22),
    rgba(59,130,246,.10)
    );

    border:
    1px solid
    rgba(196,181,253,.18);

    box-shadow:

    inset 0 0 20px
    rgba(255,255,255,.03);
}

.card-tag{

    font-size:16px;

    color:
    rgba(216,180,254,.72);

    letter-spacing:2px;
}

/* =========================
CARD TEXT
========================= */

.card-title{

    font-size:
    clamp(34px,4vw,48px);

    font-weight:900;

    line-height:1.15;

    letter-spacing:-2px;

    margin-bottom:16px;

    color:
    rgba(255,255,255,.95);
}

.card-desc{

    font-size:
    clamp(18px,2vw,24px);

    line-height:1.8;

    color:
    rgba(226,232,240,.72);
}

.card-url{

    margin-top:18px;

    font-size:13px;

    line-height:1.7;

    color:
    rgba(226,232,240,.28);

    word-break:break-all;
}

.open{

    position:absolute;

    left:36px;
    bottom:28px;

    font-size:14px;

    letter-spacing:5px;

    color:
    rgba(196,181,253,.76);
}

/* =========================
ADMIN BTN
========================= */

.admin-btn{

    position:fixed;

    right:26px;
    bottom:26px;

    width:72px;
    height:72px;

    border:none;

    border-radius:26px;

    cursor:pointer;

    font-size:30px;

    color:white;

    z-index:999;

    background:

    linear-gradient(
    135deg,
    rgba(139,92,246,.28),
    rgba(91,33,182,.16)
    );

    border:
    1px solid
    rgba(196,181,253,.18);

    backdrop-filter:blur(20px);

    box-shadow:

    0 10px 30px
    rgba(0,0,0,.35);
}

/* =========================
ADMIN PANEL
========================= */

.admin-panel{

    position:fixed;

    top:0;
    right:-480px;

    width:460px;

    height:100vh;

    overflow-y:auto;

    padding:34px;

    background:
    rgba(8,12,24,.96);

    backdrop-filter:blur(30px);

    border-left:
    1px solid
    rgba(196,181,253,.12);

    transition:.35s;

    z-index:9999;
}

.admin-panel.show{

    right:0;
}

.admin-header{

    display:flex;

    justify-content:space-between;

    align-items:center;

    margin-bottom:34px;
}

.admin-title{

    font-size:34px;

    font-weight:800;
}

.close-btn{

    width:50px;
    height:50px;

    border:none;

    border-radius:16px;

    background:
    rgba(255,255,255,.06);

    color:white;

    cursor:pointer;

    font-size:18px;
}

.input{

    width:100%;

    height:60px;

    border:none;

    outline:none;

    border-radius:18px;

    padding:0 18px;

    margin-bottom:16px;

    background:
    rgba(255,255,255,.05);

    color:white;

    font-size:17px;
}

.save-btn{

    width:100%;

    height:60px;

    border:none;

    border-radius:18px;

    cursor:pointer;

    font-size:18px;

    font-weight:800;

    color:white;

    background:

    linear-gradient(
    90deg,
    #8b5cf6,
    #7c3aed
    );
}

/* =========================
手機
========================= */

@media(max-width:980px){

    .header{

        flex-direction:column;

        gap:34px;
    }

    .clock-area{

        text-align:left;
    }

    .main{

        padding:
        52px 22px 70px;
    }

    .admin-panel{

        width:100%;

        right:-100%;
    }

    .card{

        min-height:290px;
    }
}

</style>
</head>

<body>

<!-- 星空 -->

<div class="stars" id="stars"></div>

<!-- 慕夏邊框 -->

<div class="frame">

    <div class="corner tl"></div>
    <div class="corner tr"></div>
    <div class="corner bl"></div>
    <div class="corner br"></div>

</div>

<!-- MAIN -->

<div class="main">

    <!-- HEADER -->

    <div class="header">

        <div>

            <div class="title-main">
                中正診所
            </div>

            <div class="title-sub">
                Portal
            </div>

            <div class="subtitle">

                集中所有工作入口與常用網站，
                <br>
                讓每天的工作流程更加快速順手。

            </div>

        </div>

        <!-- 時間 -->

        <div class="clock-area">

            <div
            class="clock"
            id="clock">

                00:00:00

            </div>

            <div
            class="date"
            id="date">

            </div>

        </div>

    </div>

    <!-- PRIMARY -->

    <div class="section">

        <div class="section-label">
            PRIMARY SYSTEM
        </div>

        <div
        class="grid"
        id="primaryGrid">

        </div>

    </div>

    <!-- TOOLS -->

    <div class="section">

        <div class="section-label">
            TOOLS
        </div>

        <div
        class="grid"
        id="secondaryGrid">

        </div>

    </div>

</div>

<!-- admin -->

<button
class="admin-btn"
onclick="openAdmin()">

⚙️

</button>

<!-- ADMIN PANEL -->

<div
class="admin-panel"
id="adminPanel">

    <div class="admin-header">

        <div class="admin-title">
            管理模式
        </div>

        <button
        class="close-btn"
        onclick="closeAdmin()">

            ✕

        </button>

    </div>

    <input
    class="input"
    placeholder="網站名稱">

    <input
    class="input"
    placeholder="https://">

    <button class="save-btn">

        保存設定

    </button>

</div>

<script>

/* 星空 */

const stars =
document.getElementById("stars");

for(let i=0;i<160;i++){

    const star =
    document.createElement("div");

    star.className =
    "star";

    star.style.left =
    Math.random()*100 + "%";

    star.style.top =
    Math.random()*100 + "%";

    star.style.animationDelay =
    Math.random()*5 + "s";

    stars.appendChild(star);
}

/* 時間 */

function updateClock(){

    const now =
    new Date();

    document
    .getElementById("clock")
    .innerText =

    now.toLocaleTimeString(
    "zh-TW",
    {
        hour12:false
    });

    const y =
    now.getFullYear();

    document
    .getElementById("date")
    .innerText =

    `(民${y-1911})
    ${y}/
    ${String(now.getMonth()+1).padStart(2,'0')}/
    ${String(now.getDate()).padStart(2,'0')}`;
}

updateClock();

setInterval(
updateClock,
1000
);

/* ADMIN */

const _PH =
"8227b6c507a2a6b7e6417539c36d2c416e9196b653245053f3e786b6a22287b3";

async function sha256(message){

    const msgUint8 =
    new TextEncoder().encode(message);

    const hashBuffer =
    await crypto.subtle.digest(
    'SHA-256',
    msgUint8
    );

    const hashArray =
    Array.from(
    new Uint8Array(hashBuffer)
    );

    return hashArray
    .map(
    b=>b.toString(16).padStart(2,'0')
    )
    .join('');
}

async function openAdmin(){

    const pass =
    prompt("請輸入管理密碼");

    if(!pass) return;

    const hash =
    await sha256(pass);

    if(hash === _PH){

        document
        .getElementById("adminPanel")
        .classList
        .add("show");
    }

    else{

        alert("密碼錯誤");
    }
}

function closeAdmin(){

    document
    .getElementById("adminPanel")
    .classList
    .remove("show");
}

/* links */

const coreLinks = {

primary:[

{
title:"中正診所",
url:"https://webhis.vision.com.tw/88336/login",
desc:"門診系統登入",
icon:"🩺",
tag:"HIS"
},

{
title:"VPN",
url:"https://medvpn.nhi.gov.tw/",
desc:"健保資訊網服務系統",
icon:"💻",
tag:"VPN"
},

{
title:"智慧防疫物資",
url:"https://smis.cdc.gov.tw/",
desc:"每週一登入",
icon:"📦",
tag:"CDC"
},

{
title:"雲端查詢",
url:"https://medcloud2.nhi.gov.tw/",
desc:"健保醫療資訊雲端查詢",
icon:"☁️",
tag:"CLOUD"
}

],

secondary:[

{
title:"NIIS",
url:"https://10.241.219.42/Login.aspx",
desc:"醫療院所預防接種管理子系統",
icon:"💉",
tag:"NIIS"
},

{
title:"亞東轉診",
url:"https://www.femh.org.tw/",
desc:"亞東醫院轉診服務",
icon:"🏥",
tag:"HOSPITAL"
},

{
title:"Paxlovid",
url:"https://depart.femh.org.tw/",
desc:"交互作用查詢工具",
icon:"💊",
tag:"TOOL"
},

{
title:"年份轉換",
url:"age-conv.html",
desc:"西元與民國轉換",
icon:"📅",
tag:"UTILITY"
}

]

};

/* render */

function render(){

    const fn =
    l =>

    `
    <div class="card">

        <a
        class="card-link"
        href="${l.url}"
        target="_blank">

            <div class="card-top">

                <div class="icon-box">
                    ${l.icon}
                </div>

                <div class="card-tag">
                    ${l.tag}
                </div>

            </div>

            <div class="card-title">
                ${l.title}
            </div>

            <div class="card-desc">
                ${l.desc}
            </div>

            <div class="card-url">
                ${l.url}
            </div>

            <div class="open">
                OPEN →
            </div>

        </a>

    </div>
    `;

    document
    .getElementById("primaryGrid")
    .innerHTML =

    coreLinks.primary
    .map(fn)
    .join("");

    document
    .getElementById("secondaryGrid")
    .innerHTML =

    coreLinks.secondary
    .map(fn)
    .join("");
}

render();

</script>

</body>
</html>
